{
  "name": "engineering-portfolio",
  "private": true,
  "version": "0.2.29",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "wd": "yarn build && npx wrangler dev",
    "deploy": "yarn build && npx wrangler deploy",
    "db:migrate": "npx wrangler d1 execute varun-portfolio-auth --remote --file=worker/schema.sql",
    "ingest": "node scripts/ingest-docs.js",
    "ingest:upsert": "node scripts/ingest-docs.js --upsert",
    "export:docs": "node scripts/export-docs.js",
    "lint": "eslint src",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "framer-motion": "^11.3.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^6.4.1",
    "vite-plugin-pwa": "^0.21.0"
  }
}
