# Local development environment variables.
# Copy this file to .dev.vars and fill in real values.
# .dev.vars is gitignored — never commit it.

# Override RP_ID and ORIGIN for localhost WebAuthn
ENABLE_AUTH=true
RP_ID=localhost
ORIGIN=http://localhost:8787

# Admin account email
ADMIN_EMAIL=you@example.com

# Resend API key — https://resend.com
RESEND_API_KEY=re_your_key_here

# 32-byte hex key for AES-256-GCM TOTP secret encryption
# Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=your_64_char_hex_key_here

# Twilio credentials — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
