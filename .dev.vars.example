# Local development secrets.
# Copy this file to .dev.vars and fill in real values.
# .dev.vars is gitignored — never committed.
#
# Non-sensitive dev vars (RP_ID, ORIGIN, ENABLE_AUTH) are set in wrangler.toml [vars].
# Only secrets that differ from production need to be listed here.

# Admin account email
ADMIN_EMAIL=you@example.com

# Resend API key — https://resend.com
RESEND_API_KEY=re_your_key_here

# 32-byte hex key for AES-256-GCM TOTP secret encryption
# Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=your_64_char_hex_key_here

# Twilio credentials — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Anthropic API key — https://console.anthropic.com
# Required for the LLM Eval Pipeline tab in the admin dashboard.
# Production: npx wrangler secret put ANTHROPIC_API_KEY --env production
ANTHROPIC_API_KEY=sk-ant-your_key_here
